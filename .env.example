# Local Data Studio normally reads paths, server settings, EDA, Atlas, and
# deletion settings from local_data_studio.toml. Start it with:
#
#   local-data-studio --config ./local_data_studio.toml
#
# Use this .env file for provider credentials and, only when needed, local
# overrides. Uncomment and edit only the values you need. OS environment
# variables override TOML, and TOML overrides this file.
#
# LOCAL_DATA_STUDIO_CONFIG_FILE must be exported before startup; placing it in
# this .env file cannot select the TOML file that loads this .env file.

# LLM provider credentials. The corresponding [[llm.models]] profile uses the
# variable name specified by api_key_env.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# Dataset and runtime paths. Prefer the [paths] section in local_data_studio.toml.
# DATA_FILE=/absolute/path/to/dataset.parquet
# DATA_DIR=/absolute/path/to/datasets
# CACHE_DIR=/absolute/path/to/cache
# EMBEDDER_MODELS_DIR=/absolute/path/to/models/embedder
# FILE_SERVE_ROOTS=/absolute/path/to/datasets,/absolute/path/to/images
# VIS_EXCLUDE_DIRS=archive,temporary
# VIS_EXCLUDE_FILES=archive.csv,temporary/old.parquet

# EDA settings. Prefer the [settings] section in local_data_studio.toml.
# EDA_ROW_LIMIT=50000
# EDA_CELL_MAX_CHARS=5000
# EDA_NESTED_POLICY=stringify
# EDA_CACHE_MAX_BYTES=1073741824

# Embedding Atlas settings. Prefer the [settings] section in local_data_studio.toml.
# ATLAS_HOST=127.0.0.1
# ATLAS_PORT=5055
# ATLAS_SAMPLE=0
# ATLAS_BATCH_SIZE=0
# ATLAS_CACHE_MAX_BYTES=10737418240
# ATLAS_TEXT_MAX_CHARS=4096
# ATLAS_EMBEDDING_DTYPE=float32
# ATLAS_UMAP_PROJECTION_MODE=full
# ATLAS_UMAP_ANCHOR_SAMPLE=10000
# ATLAS_TRUST_REMOTE_CODE=false

# Source-file deletion. Prefer allow_delete_data in local_data_studio.toml.
# ALLOW_DELETE_DATA=false
